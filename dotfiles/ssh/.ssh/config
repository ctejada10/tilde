UseRoaming no

Host *
  AddKeysToAgent yes
  IgnoreUnknown UseKeychain
  UseKeychain yes
  ServerAliveInterval 60
  IdentityFile ~/.ssh/personal

Host */*
  ProxyCommand ssh $(dirname %h) -W $(basename %h):%p

Host github.com
  IdentityFile ~/.ssh/personal
Host gitlab.com
  IdentityFile ~/.ssh/work

Host erebor
  HostName erebor.middlearth.io
  ForwardAgent yes
  User ctejada

Host rivendell
  HostName rivendell.middlearth.io
  User ctejada
