UseRoaming no

Host *
  AddKeysToAgent yes
  IgnoreUnknown UseKeychain
  UseKeychain yes
  ServerAliveInterval 60
  IdentityFile ~/.ssh/personal

Host */*
  ProxyCommand ssh $(dirname %h) -W $(basename %h):%p

Host erebor
  HostName erebor.middlearth.io
  ForwardAgent yes
  User ctejada
  ExitOnForwardFailure yes
  RemoteForward /run/user/1000/gnupg/S.gpg-agent /Users/ctejada/.gnupg/S.gpg-agent.extra

Host rivendell
  HostName rivendell.middlearth.io
  ForwardAgent yes
  User ctejada

Host mordor
  HostName mordor.middlearth.io
  ForwardAgent yes
  User ctejada
