#!/usr/bin/env bash
# Ubuntu setup script for root execution
# Usage: ./ubuntu <repo_tmp_dir>

set -euo pipefail

REPO_TMP_DIR="${1:-/tmp/tilde-setup}"
USER_NAME="ctejada"
USER_PASS="1234"
USER_HOME="/home/${USER_NAME}"
SRC_DIR="${USER_HOME}/src"
REPO_DIR="${SRC_DIR}/tilde"

# 1. Create user ctejada with password and force password change on first login
if ! id "$USER_NAME" &>/dev/null; then
    echo "[*] Creating user $USER_NAME..."
    useradd -m -s /bin/bash "$USER_NAME"
    echo "$USER_NAME:$USER_PASS" | chpasswd
    chage -d 0 "$USER_NAME"
else
    echo "[*] User $USER_NAME already exists. Skipping creation."
fi

# 2. Create /home/ctejada/src and clone repo
mkdir -p "$SRC_DIR"
if [ ! -d "$REPO_DIR" ]; then
    echo "[*] Copying repository to $REPO_DIR..."
    cp -a "$REPO_TMP_DIR" "$REPO_DIR"
    chown -R "$USER_NAME:$USER_NAME" "$REPO_DIR"
else
    echo "[*] Repository already exists at $REPO_DIR. Skipping copy."
fi


# 3. Install apps from .apt (must be before stow)
cd "$REPO_DIR/scripts"
chmod +x .apt
./.apt

# 4. Stow dotfiles (btop, git, gpg, ssh, tmux, zsh)
cd "$REPO_DIR/dotfiles"
for d in btop git gpg ssh tmux zsh; do
    if [ -d "$d" ]; then
        echo "[*] Stowing $d..."
        stow -t "$USER_HOME" "$d"
    fi
done
chown -R "$USER_NAME:$USER_NAME" "$USER_HOME"

# 5. Install oh-my-zsh for ctejada
OH_MY_ZSH_DIR="$USER_HOME/.oh-my-zsh"
if [ ! -d "$OH_MY_ZSH_DIR" ]; then
    echo "[*] Installing oh-my-zsh for $USER_NAME..."
    sudo -u "$USER_NAME" sh -c "RUNZSH=no CHSH=no KEEP_ZSHRC=yes bash -c '$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)'"
fi

# 6. Set default shell to zsh for ctejada
chsh -s "$(which zsh)" "$USER_NAME"

# 7. Run hardening-ubuntu.sh
chmod +x "$REPO_DIR/scripts/hardening-ubuntu.sh"
"$REPO_DIR/scripts/hardening-ubuntu.sh"

echo "[*] Setup complete. User $USER_NAME created, dotfiles stowed, apps installed, oh-my-zsh set up, and system hardened."
