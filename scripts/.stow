#!/usr/bin/env bash

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DOTFILES_DIR="$REPO_DIR/dotfiles"
TARGET_DIR="$HOME"

usage() {
  echo "Usage: $(basename "$0") [package ...]"
  echo "If no packages are provided, stows all packages in dotfiles/"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -gt 0 ]]; then
  packages=("$@")
else
  packages=()
  for d in "$DOTFILES_DIR"/*/; do
    packages+=("$(basename "$d")")
  done
fi

cd "$DOTFILES_DIR"

for pkg in "${packages[@]}"; do
  if [[ ! -d "$DOTFILES_DIR/$pkg" ]]; then
    echo "Warning: package not found: $pkg — skipping"
    continue
  fi
  echo "Stowing $pkg..."
  stow -v -t "$TARGET_DIR" "$pkg"
done

echo "Done."
